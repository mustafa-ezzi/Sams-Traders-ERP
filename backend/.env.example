# Railway PostgreSQL (required for local dev)
# In Railway: open your Postgres service → Variables → copy DATABASE_PUBLIC_URL
# Or copy PGHOST + PGPORT + PGUSER + PGPASSWORD + PGDATABASE from the same service.
#
# IMPORTANT: For connections from your PC, use DATABASE_PUBLIC_URL (or PGHOST + PGPORT).
# Port 5432 is only for internal Railway networking — the public TCP proxy uses a
# different port (e.g. 28471). Using 5432 with *.proxy.rlwy.net will time out.

DATABASE_PUBLIC_URL=postgresql://postgres:NljhxDKeBLPdPCdtJIIcdAeEdUbxFJDj@acela.proxy.rlwy.net:10900/railway

# Alternative (individual variables from the Postgres service):
# PGHOST=postgres.railway.internal
# PGPORT=YOUR_PROXY_PORT
# PGUSER=postgres
# PGPASSWORD=NljhxDKeBLPdPCdtJIIcdAeEdUbxFJDj
# PGDATABASE=railway

# Emergency local-only fallback (not for normal use):
# USE_SQLITE=true
